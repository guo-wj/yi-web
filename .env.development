# 配置文档参考 https://taro-docs.jd.com/docs/next/env-mode-config
# TARO_APP_ID="开发环境下的小程序 AppID"

# H5 开发后端地址
# - 本地：浏览器直连 http://127.0.0.1:8000（绕过 devServer 代理，避免系统 HTTP 代理导致 404）
TARO_APP_API_URL=http://127.0.0.1:8000
# - 远程：走 devServer 代理 /api -> 远程（取消下行注释并注释掉上面本地行）
# TARO_APP_API_URL=http://39.107.249.82

# 可选：强制指定 API 根地址（一般不需要）
# TARO_APP_API_BASE=http://127.0.0.1:8000
